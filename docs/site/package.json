{
  "name": "solo-docs",
  "version": "0.0.0",
  "version.next": "0.0.1",
  "description": "Solo technical documentation.",
  "repository": "github:hiero-ledger/solo",
  "homepage": "https://solo.hiero.org/",
  "author": "Hashgraph",
  "license": "Apache-2.0",
  "bugs": "https://github.com/hiero-ledger/solo/issues",
  "spelling": "cSpell:ignore docsy hugo htmltest precheck postbuild rtlcss -",
  "scripts": {
    "_build": "npm run _hugo-dev --",
    "_hugo": "hugo --cleanDestinationDir",
    "_hugo-dev": "npm run _hugo -- -e dev -DFE",
    "_local": "npx cross-env HUGO_MODULE_WORKSPACE=docsy.work",
    "_serve": "npm run _hugo-dev -- --minify serve --renderToMemory",
    "build:preview": "npm run _hugo-dev -- --minify --baseURL \"${DEPLOY_PRIME_URL:-/}\"",
    "build:production": "npm run _hugo -- --minify",
    "build": "npm run _build -- ",
    "clean": "rm -Rf public/* resources",
    "local": "npm run _local -- npm run",
    "precheck:links:all": "npm run build",
    "precheck:links": "npm run build",
    "serve": "npm run _serve"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "hugo-extended": "0.145.0",
    "postcss-cli": "^11.0.1",
    "rtlcss": "^4.3.0"
  },
  "private": true,
  "prettier": {
    "proseWrap": "always",
    "singleQuote": true
  }
}
