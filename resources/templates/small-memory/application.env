# Small-memory JVM parameters for consensus node
# Source: hiero-consensus-node/hedera-node/docker/start-small-memory.sh
# Note: JFR (-XX:StartFlightRecording) is omitted because Solo does not currently
# support mounting the MemoryLowOverhead.jfc file into the container.
JAVA_HEAP_MIN=1g
JAVA_HEAP_MAX=1g
JAVA_OPTS=-XX:+UseG1GC -XX:+AlwaysPreTouch -XX:MaxMetaspaceSize=84M -XX:CompressedClassSpaceSize=48M -Xss256K -XX:ReservedCodeCacheSize=24M -XX:MaxDirectMemorySize=16M -Dio.netty.allocator.type=unpooled -Djava.util.concurrent.ForkJoinPool.common.parallelism=2
MALLOC_ARENA_MAX=1