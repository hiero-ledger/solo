# Small-memory JVM parameters for consensus node
# Source: hiero-consensus-node/hedera-node/docker/start-small-memory.sh
# Note: JFR (-XX:StartFlightRecording) is omitted because Solo does not currently
# support mounting the MemoryLowOverhead.jfc file into the container.
JAVA_HEAP_MIN=256m
JAVA_HEAP_MAX=256m
JAVA_OPTS=-XX:+UseSerialGC -XX:+AlwaysPreTouch -XX:MaxMetaspaceSize=84M -XX:CompressedClassSpaceSize=48M -Xss256K -XX:-TieredCompilation -XX:CICompilerCount=1 -XX:ReservedCodeCacheSize=24M -XX:MaxDirectMemorySize=16M -Dio.netty.allocator.type=unpooled -Djava.util.concurrent.ForkJoinPool.common.parallelism=2 
MALLOC_ARENA_MAX=1