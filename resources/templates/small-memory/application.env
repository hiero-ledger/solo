# Small-memory JVM parameters for consensus node
# Source: hiero-consensus-node/hedera-node/docker/start-small-memory.sh
# Note: JFR (-XX:StartFlightRecording) is omitted because Solo does not currently
# support mounting the MemoryLowOverhead.jfc file into the container.
JAVA_HEAP_MIN=196m
JAVA_HEAP_MAX=196m
JAVA_OPTS=-XX:+UseSerialGC -XX:+AlwaysPreTouch -XX:MaxMetaspaceSize=84M -XX:CompressedClassSpaceSize=48M -Xss256K -XX:-TieredCompilation -XX:CICompilerCount=1 -XX:ReservedCodeCacheSize=24M -XX:MaxDirectMemorySize=16M -XX:NativeMemoryTracking=summary -Dio.netty.allocator.type=unpooled -Djava.util.concurrent.ForkJoinPool.common.parallelism=2 --limit-modules=java.base,java.compiler,java.desktop,java.logging,java.management,java.naming,java.net.http,java.prefs,java.rmi,java.scripting,java.security.jgss,java.security.sasl,java.sql,java.transaction.xa,java.xml,java.xml.crypto,jdk.crypto.cryptoki,jdk.crypto.ec,jdk.httpserver,jdk.jfr,jdk.management,jdk.management.jfr,jdk.naming.dns,jdk.net,jdk.unsupported,jdk.zipfs
